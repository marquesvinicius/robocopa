# =============================================================
# CONFIGURAÇÕES DO ROBOCOPA — Copa do Mundo 2026
# Copie este arquivo para .env e preencha as chaves
# =============================================================

# Token do Bot Telegram
# Obtenha com @BotFather no Telegram: /newbot
TELEGRAM_TOKEN=seu_token_telegram_aqui

# Chave da API Gemini (Google AI Studio)
# Obtenha GRATUITAMENTE em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# Modelo Gemini a usar
# Opções recomendadas (2026):
#   gemini-2.5-flash-lite   ← rápido, gratuito, recomendado para este projeto
#   gemini-flash-latest     ← sempre aponta para o Flash mais recente
#   gemini-2.5-flash        ← mais capaz (pode ter fila em horário de pico)
# Evite: gemini-2.0-flash (descontinuado para novos usuários)
# Recomendado: flash-lite (function calling mais estável que gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash-lite

# ─────────────────────────────────────────────────────────────
# BUSCA WEB — Escolha um dos provedores abaixo
# ─────────────────────────────────────────────────────────────

# Provedor de busca: "tavily" (recomendado) ou "serper"
SEARCH_PROVIDER=tavily

# Tavily API (recomendado — otimizada para LLMs)
# Plano gratuito disponível em: https://tavily.com
TAVILY_API_KEY=sua_chave_tavily_aqui

# Serper API (alternativa — baseia-se no Google)
# Plano gratuito disponível em: https://serper.dev
# Descomente e preencha se usar SEARCH_PROVIDER=serper
# SERPER_API_KEY=sua_chave_serper_aqui

# ─────────────────────────────────────────────────────────────
# CONFIGURAÇÕES DE MEMÓRIA E COMPORTAMENTO
# ─────────────────────────────────────────────────────────────

# Número máximo de mensagens no contexto enviado à API
# 10 = últimas 5 trocas de mensagem (1 user + 1 assistant = 1 troca)
MAX_HISTORY=10

# Modo debug: "true" mostra informações extras no terminal
DEBUG=false

# ─────────────────────────────────────────────────────────────
# API-FOOTBALL — Dados estruturados da Copa 2026
# ─────────────────────────────────────────────────────────────

# Chave gratuita (100 req/dia): https://dashboard.api-football.com
# Sem essa chave o bot usa o fallback openfootball (menos dados, sem ao vivo)
# Plano Free: temporada 2026 completa NÃO incluída — apenas janela reduzida de datas
API_FOOTBALL_KEY=sua_chave_api_football_aqui

# Host da API (não altere salvo se usar RapidAPI diretamente)
# API_FOOTBALL_HOST=v3.football.api-sports.io

# ─────────────────────────────────────────────────────────────
# FOOTBALL-DATA.ORG — 2ª Fonte Estruturada (Copa 2026, gratuita)
# ─────────────────────────────────────────────────────────────

# Chave gratuita: https://www.football-data.org/client/register
# Free plan: 10 req/min, Copa 2026 inclusa (competition code: WC)
# Oferece: jogos, classificação, artilheiros — atraso ~1 min no ao vivo
# Se configurada, torna-se a 2ª fonte (após API-Football, antes de openfootball)
FOOTBALL_DATA_KEY=seu_token_football_data_aqui

# ─────────────────────────────────────────────────────────────
# NOTIFICAÇÕES PROATIVAS — JobQueue (Fase 2)
# ─────────────────────────────────────────────────────────────

# Intervalo em minutos entre verificações de alertas (pré-jogo, escalação, resultado)
# Valor mínimo recomendado: 5. Valores muito baixos aumentam consumo de quota.
NOTIFICATION_CHECK_INTERVAL_MIN=5

# ─────────────────────────────────────────────────────────────
# RENDER.COM — Deploy em produção
# ─────────────────────────────────────────────────────────────

# Porta do servidor HTTP de saúde (Render seta automaticamente; padrão local: 8080)
# PORT=8080

# URL externa do serviço Render (setada automaticamente pelo Render ao fazer deploy)
# Usado para keep-alive: o bot pinga /health a cada 14 min para evitar sleep
# RENDER_EXTERNAL_URL=https://robocopa.onrender.com

# ─────────────────────────────────────────────────────────────
# REDIS — Persistência de preferências e alertas
# ─────────────────────────────────────────────────────────────

# URL de conexão Redis (Render seta automaticamente se você adicionar o addon Redis)
# Sem essa variável, o bot usa fallback em arquivo (funciona localmente)
# Para desenvolvimento local com Redis: redis://localhost:6379
# REDIS_URL=redis://localhost:6379
